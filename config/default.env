# Path to the Android repo to build.
ANDROID_REPO_PATH="../ottclouds-android"

# Branch to monitor for merged pull requests.
DEPLOY_GIT_BRANCH="main"

# GitHub API endpoint and scan limit.
GITHUB_API_URL="https://api.github.com"
MAX_PULLS_TO_SCAN="100"

# Where this tool stores last processed merged PR information.
STATE_DIR=".state"

# Build command executed inside ANDROID_REPO_PATH.
BUILD_COMMAND="./gradlew :app-mobile:assembleVideohubDevRelease :app-tv:assembleVideohubDevRelease :app-tv:assembleSerieshubDevRelease :app-tv:assembleLiveHubDevRelease"

# APK output folders relative to ANDROID_REPO_PATH.
MOBILE_APK_OUTPUT_DIR="app-mobile/build/outputs/apk"
TV_APK_OUTPUT_DIR="app-tv/build/outputs/apk"

# Distribution toggles.
ENABLE_MOBILE_DISTRIBUTION="true"
ENABLE_TV_DISTRIBUTION="true"

# Behavior when APKs are not found.
FAIL_IF_APK_NOT_FOUND="true"
ALLOW_STALE_APK_FALLBACK="true"

# Firebase CLI command name.
FIREBASE_CLI_BIN="firebase"

# Firebase App IDs (must be configured in .env).
FIREBASE_APP_ID_MOBILE=""
FIREBASE_APP_ID_TV=""

# Comma-separated Firebase tester groups (optional).
FIREBASE_GROUPS_MOBILE=""
FIREBASE_GROUPS_TV=""

# Comma-separated tester emails (optional).
FIREBASE_TESTERS_MOBILE=""
FIREBASE_TESTERS_TV=""

# Optional release notes or release notes file path.
FIREBASE_RELEASE_NOTES=""
FIREBASE_RELEASE_NOTES_FILE=""

# Optional explicit repo owner/name (auto-detected from remote if empty).
GITHUB_OWNER=""
GITHUB_REPO=""
