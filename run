  EFFECTIVE_BUILD_COMMAND_TV=${EFFECTIVE_BUILD_COMMAND_TV:-}
  EFFECTIVE_BUILD_COMMAND_MOBILE=${EFFECTIVE_BUILD_COMMAND_MOBILE:-}
  MAX_MERGE_COMMITS_SCAN=$MAX_MERGE_COMMITS_SCAN
