#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_CONFIG_FILE="$SCRIPT_DIR/config/default.env"
LOCAL_CONFIG_FILE="$SCRIPT_DIR/.env"

CLI_CONFIG_FILE=""
CLI_BRANCH=""
FORCE_BUILD="false"
DRY_RUN="false"
PRINT_CONFIG="false"

usage() {
  cat <<'__USAGE__'
Usage: ./run [options]

Options:
  --config <file>     Load an extra env file after .env
  --branch <name>     Override DEPLOY_GIT_BRANCH
  --force-build       Build and distribute without waiting for a new merged PR
  --dry-run           Print planned actions without building or uploading
  --print-config      Print effective configuration (secrets are masked)
  -h, --help          Show help
__USAGE__
}

log() {
  printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*"
}

warn() {
  printf '[%s] WARNING: %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" >&2
}

die() {
  printf '[%s] ERROR: %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" >&2
  exit 1
}

is_truthy() {
  case "$(printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]')" in
    1|true|yes|y|on) return 0 ;;
    *) return 1 ;;
  esac
}

mask_secret() {
  local value="${1:-}"
  if [[ -z "$value" ]]; then
    printf ''
    return 0
  fi

  if [[ ${#value} -le 6 ]]; then
    printf '***'
  else
    printf '%s***%s' "${value:0:3}" "${value: -3}"
  fi
}

load_env_file() {
  local file="$1"
  if [[ -f "$file" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$file"
    set +a
  fi
}

resolve_path() {
  local candidate="$1"
  local base="$2"

  case "$candidate" in
    /*) printf '%s\n' "$candidate" ;;
    *) printf '%s\n' "$base/$candidate" ;;
  esac
}

parse_arguments() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --config)
        [[ $# -ge 2 ]] || die "Missing value for --config"
        CLI_CONFIG_FILE="$2"
        shift 2
        ;;
      --branch)
        [[ $# -ge 2 ]] || die "Missing value for --branch"
        CLI_BRANCH="$2"
        shift 2
        ;;
      --force-build)
        FORCE_BUILD="true"
        shift
        ;;
      --dry-run)
        DRY_RUN="true"
        shift
        ;;
      --print-config)
        PRINT_CONFIG="true"
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "Unknown option: $1"
        ;;
    esac
  done
}

require_command() {
  local command_name="$1"
  command -v "$command_name" >/dev/null 2>&1 || die "Missing required command: $command_name"
}

parse_owner_repo_from_remote() {
  local repo_path="$1"
  local remote_url
  local slug

  remote_url="$(git -C "$repo_path" config --get remote.origin.url || true)"
  [[ -n "$remote_url" ]] || die "Cannot read remote.origin.url from $repo_path"

  slug="$remote_url"
  slug="${slug#git@github.com:}"
  slug="${slug#https://github.com/}"
  slug="${slug%.git}"

  if [[ "$slug" != */* ]]; then
    die "Unsupported GitHub remote URL format: $remote_url"
  fi

  GITHUB_OWNER="${slug%%/*}"
  GITHUB_REPO="${slug##*/}"
}

github_api_get_closed_prs() {
  local owner="$1"
  local repo="$2"
  local branch="$3"
  local encoded_branch
  local api_url
  local response_file
  local status_code

  encoded_branch="$(printf '%s' "$branch" | jq -sRr @uri)"
  api_url="${GITHUB_API_URL%/}/repos/$owner/$repo/pulls?state=closed&base=$encoded_branch&sort=updated&direction=desc&per_page=$MAX_PULLS_TO_SCAN"

  response_file="$(mktemp)"

  if [[ -n "${GITHUB_TOKEN:-}" ]]; then
    status_code="$(curl -sS -o "$response_file" -w '%{http_code}' \
      -H 'Accept: application/vnd.github+json' \
      -H "Authorization: Bearer $GITHUB_TOKEN" \
      -H 'X-GitHub-Api-Version: 2022-11-28' \
      -H 'User-Agent: ott-clouds-ci-cd' \
      "$api_url")"
  else
    status_code="$(curl -sS -o "$response_file" -w '%{http_code}' \
      -H 'Accept: application/vnd.github+json' \
      -H 'X-GitHub-Api-Version: 2022-11-28' \
      -H 'User-Agent: ott-clouds-ci-cd' \
      "$api_url")"
  fi

  if [[ "$status_code" -lt 200 || "$status_code" -gt 299 ]]; then
    local api_message
    api_message="$(jq -r '.message // empty' "$response_file" 2>/dev/null || true)"
    rm -f "$response_file"
    if [[ -n "$api_message" ]]; then
      die "GitHub API request failed ($status_code): $api_message"
    fi
    die "GitHub API request failed with HTTP $status_code"
  fi

  cat "$response_file"
  rm -f "$response_file"
}

latest_merged_pr_json() {
  local closed_prs_json="$1"
  local branch="$2"

  printf '%s' "$closed_prs_json" | jq -c --arg branch "$branch" '
    [.[] | select(.merged_at != null and .base.ref == $branch)]
    | sort_by(.merged_at)
    | last // empty
  '
}

read_state_value() {
  local key="$1"
  local state_file="$2"

  if [[ ! -f "$state_file" ]]; then
    printf ''
    return 0
  fi

  jq -r --arg key "$key" '.[$key] // empty' "$state_file" 2>/dev/null || true
}

print_config() {
  cat <<__CONFIG__
Effective configuration:
  ANDROID_REPO_PATH=$ANDROID_REPO_PATH
  DEPLOY_GIT_BRANCH=$DEPLOY_GIT_BRANCH
  GITHUB_OWNER=$GITHUB_OWNER
  GITHUB_REPO=$GITHUB_REPO
  GITHUB_API_URL=$GITHUB_API_URL
  MAX_PULLS_TO_SCAN=$MAX_PULLS_TO_SCAN
  BUILD_COMMAND=$BUILD_COMMAND
  MOBILE_APK_OUTPUT_DIR=$MOBILE_APK_OUTPUT_DIR
  TV_APK_OUTPUT_DIR=$TV_APK_OUTPUT_DIR
  ENABLE_MOBILE_DISTRIBUTION=$ENABLE_MOBILE_DISTRIBUTION
  ENABLE_TV_DISTRIBUTION=$ENABLE_TV_DISTRIBUTION
  FAIL_IF_APK_NOT_FOUND=$FAIL_IF_APK_NOT_FOUND
  ALLOW_STALE_APK_FALLBACK=$ALLOW_STALE_APK_FALLBACK
  FIREBASE_CLI_BIN=$FIREBASE_CLI_BIN
  FIREBASE_APP_ID_MOBILE=$FIREBASE_APP_ID_MOBILE
  FIREBASE_APP_ID_TV=$FIREBASE_APP_ID_TV
  FIREBASE_GROUPS_MOBILE=$FIREBASE_GROUPS_MOBILE
  FIREBASE_GROUPS_TV=$FIREBASE_GROUPS_TV
  FIREBASE_TESTERS_MOBILE=$FIREBASE_TESTERS_MOBILE
  FIREBASE_TESTERS_TV=$FIREBASE_TESTERS_TV
  FIREBASE_RELEASE_NOTES_FILE=$FIREBASE_RELEASE_NOTES_FILE
  GITHUB_TOKEN=$(mask_secret "${GITHUB_TOKEN:-}")
  FIREBASE_TOKEN=$(mask_secret "${FIREBASE_TOKEN:-}")
  STATE_FILE=$STATE_FILE
  FORCE_BUILD=$FORCE_BUILD
  DRY_RUN=$DRY_RUN
__CONFIG__
}

run_build() {
  local repo_path="$1"
  local command_text="$2"

  if is_truthy "$DRY_RUN"; then
    log "[DRY-RUN] Build command: $command_text"
    return 0
  fi

  log "Running build command in $repo_path"
  (
    cd "$repo_path"
    bash -lc "$command_text"
  )
}

collect_apks() {
  local output_dir="$1"
  local marker_file="$2"
  local allow_stale="$3"

  if [[ ! -d "$output_dir" ]]; then
    return 0
  fi

  find "$output_dir" -type f -name '*.apk' -newer "$marker_file" | sort

  if is_truthy "$allow_stale"; then
    local count
    count="$(find "$output_dir" -type f -name '*.apk' -newer "$marker_file" | wc -l | tr -d ' ')"
    if [[ "$count" == "0" ]]; then
      find "$output_dir" -type f -name '*.apk' | sort
    fi
  fi
}

read_release_notes() {
  local default_notes="$1"

  if [[ -n "${FIREBASE_RELEASE_NOTES_FILE:-}" ]]; then
    local notes_file
    notes_file="$(resolve_path "$FIREBASE_RELEASE_NOTES_FILE" "$SCRIPT_DIR")"
    [[ -f "$notes_file" ]] || die "FIREBASE_RELEASE_NOTES_FILE not found: $notes_file"
    cat "$notes_file"
    return 0
  fi

  if [[ -n "${FIREBASE_RELEASE_NOTES:-}" ]]; then
    printf '%s\n' "$FIREBASE_RELEASE_NOTES"
    return 0
  fi

  printf '%s\n' "$default_notes"
}

distribute_apks() {
  local channel_name="$1"
  local app_id="$2"
  local groups="$3"
  local testers="$4"
  local release_notes="$5"
  shift 5
  local apks=("$@")

  if [[ ${#apks[@]} -eq 0 ]]; then
    log "No APK files found for $channel_name"
    return 0
  fi

  [[ -n "$app_id" ]] || die "Missing Firebase app id for $channel_name"

  local apk
  for apk in "${apks[@]}"; do
    local cmd=("$FIREBASE_CLI_BIN" "appdistribution:distribute" "$apk" "--app" "$app_id" "--release-notes" "$release_notes")

    if [[ -n "$groups" ]]; then
      cmd+=("--groups" "$groups")
    fi

    if [[ -n "$testers" ]]; then
      cmd+=("--testers" "$testers")
    fi

    if [[ -n "${FIREBASE_TOKEN:-}" ]]; then
      cmd+=("--token" "$FIREBASE_TOKEN")
    fi

    if is_truthy "$DRY_RUN"; then
      printf '[DRY-RUN] Firebase command:'
      printf ' %q' "${cmd[@]}"
      printf '\n'
    else
      log "Uploading $apk to Firebase App Distribution ($channel_name)"
      "${cmd[@]}"
    fi
  done
}

save_state() {
  local state_file="$1"
  local branch="$2"
  local pr_number="$3"
  local pr_merged_at="$4"
  local pr_url="$5"

  if is_truthy "$DRY_RUN"; then
    log "[DRY-RUN] Skip updating state file"
    return 0
  fi

  cat > "$state_file" <<__STATE__
{
  "branch": "$branch",
  "last_processed_pr_number": "$pr_number",
  "last_processed_pr_merged_at": "$pr_merged_at",
  "last_processed_pr_url": "$pr_url",
  "updated_at_utc": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
}
__STATE__
}

run() {
  parse_arguments "$@"

  load_env_file "$DEFAULT_CONFIG_FILE"
  load_env_file "$LOCAL_CONFIG_FILE"

  if [[ -n "$CLI_CONFIG_FILE" ]]; then
    CLI_CONFIG_FILE="$(resolve_path "$CLI_CONFIG_FILE" "$SCRIPT_DIR")"
    [[ -f "$CLI_CONFIG_FILE" ]] || die "Config file not found: $CLI_CONFIG_FILE"
    load_env_file "$CLI_CONFIG_FILE"
  fi

  : "${DEPLOY_GIT_BRANCH:=main}"
  : "${GITHUB_API_URL:=https://api.github.com}"
  : "${MAX_PULLS_TO_SCAN:=100}"
  : "${ANDROID_REPO_PATH:=../ottclouds-android}"
  : "${STATE_DIR:=.state}"
  : "${BUILD_COMMAND:=./gradlew :app-mobile:assembleRelease :app-tv:assembleRelease}"
  : "${MOBILE_APK_OUTPUT_DIR:=app-mobile/build/outputs/apk}"
  : "${TV_APK_OUTPUT_DIR:=app-tv/build/outputs/apk}"
  : "${ENABLE_MOBILE_DISTRIBUTION:=true}"
  : "${ENABLE_TV_DISTRIBUTION:=true}"
  : "${FAIL_IF_APK_NOT_FOUND:=true}"
  : "${ALLOW_STALE_APK_FALLBACK:=true}"
  : "${FIREBASE_CLI_BIN:=firebase}"
  : "${FIREBASE_APP_ID_MOBILE:=}"
  : "${FIREBASE_APP_ID_TV:=}"
  : "${FIREBASE_GROUPS_MOBILE:=}"
  : "${FIREBASE_GROUPS_TV:=}"
  : "${FIREBASE_TESTERS_MOBILE:=}"
  : "${FIREBASE_TESTERS_TV:=}"
  : "${FIREBASE_RELEASE_NOTES:=}"
  : "${FIREBASE_RELEASE_NOTES_FILE:=}"

  if [[ -n "$CLI_BRANCH" ]]; then
    DEPLOY_GIT_BRANCH="$CLI_BRANCH"
  fi

  ANDROID_REPO_PATH="$(resolve_path "$ANDROID_REPO_PATH" "$SCRIPT_DIR")"
  STATE_DIR="$(resolve_path "$STATE_DIR" "$SCRIPT_DIR")"
  mkdir -p "$STATE_DIR"

  STATE_FILE="$STATE_DIR/${DEPLOY_GIT_BRANCH//\//_}.json"

  if [[ ! -d "$ANDROID_REPO_PATH/.git" ]]; then
    die "ANDROID_REPO_PATH is not a git repo: $ANDROID_REPO_PATH"
  fi

  require_command git
  require_command curl
  require_command jq
  require_command find

  if ! is_truthy "$DRY_RUN"; then
    if is_truthy "$ENABLE_MOBILE_DISTRIBUTION" || is_truthy "$ENABLE_TV_DISTRIBUTION"; then
      require_command "$FIREBASE_CLI_BIN"
    fi
  fi

  if [[ -z "${GITHUB_OWNER:-}" || -z "${GITHUB_REPO:-}" ]]; then
    parse_owner_repo_from_remote "$ANDROID_REPO_PATH"
  fi

  if is_truthy "$PRINT_CONFIG"; then
    print_config
  fi

  has_real_merged_pr="false"
  if is_truthy "$FORCE_BUILD"; then
    latest_pr_number="manual"
    latest_pr_title="Manual force build"
    latest_pr_url="N/A"
    latest_pr_merged_at="$(date -u +'%Y-%m-%dT%H:%M:%SZ')"
    log "Force build mode: skip merged PR query."
  else
    log "Checking merged PRs for $GITHUB_OWNER/$GITHUB_REPO on branch $DEPLOY_GIT_BRANCH"
    closed_prs_json="$(github_api_get_closed_prs "$GITHUB_OWNER" "$GITHUB_REPO" "$DEPLOY_GIT_BRANCH")"
    latest_pr="$(latest_merged_pr_json "$closed_prs_json" "$DEPLOY_GIT_BRANCH")"
    if [[ -z "$latest_pr" ]]; then
      log "No merged PR found on branch $DEPLOY_GIT_BRANCH"
      exit 0
    fi

    has_real_merged_pr="true"
    latest_pr_number="$(printf '%s' "$latest_pr" | jq -r '.number')"
    latest_pr_title="$(printf '%s' "$latest_pr" | jq -r '.title')"
    latest_pr_url="$(printf '%s' "$latest_pr" | jq -r '.html_url')"
    latest_pr_merged_at="$(printf '%s' "$latest_pr" | jq -r '.merged_at')"
  fi

  if [[ -z "${latest_pr_number:-}" || -z "${latest_pr_merged_at:-}" ]]; then
    if is_truthy "$FORCE_BUILD"; then
      latest_pr_number="manual"
      latest_pr_title="Manual force build"
      latest_pr_url="N/A"
      latest_pr_merged_at="$(date -u +'%Y-%m-%dT%H:%M:%SZ')"
    else
      die "Unable to read merged PR metadata."
    fi
  fi

  last_processed_pr_number="$(read_state_value 'last_processed_pr_number' "$STATE_FILE")"
  last_processed_pr_merged_at="$(read_state_value 'last_processed_pr_merged_at' "$STATE_FILE")"

  if ! is_truthy "$FORCE_BUILD" && is_truthy "$has_real_merged_pr"; then
    if [[ -n "$last_processed_pr_merged_at" ]]; then
      if [[ "$latest_pr_merged_at" < "$last_processed_pr_merged_at" || "$latest_pr_merged_at" == "$last_processed_pr_merged_at" ]]; then
        if [[ "$latest_pr_number" == "$last_processed_pr_number" ]]; then
          log "No new merged PR since last run (last processed PR #$last_processed_pr_number)"
          exit 0
        fi
      fi
    fi
  fi

  if is_truthy "$FORCE_BUILD"; then
    log "Force build enabled. Skip PR freshness check."
  else
    log "New merged PR detected: #$latest_pr_number - $latest_pr_title"
  fi

  build_marker_file="$STATE_DIR/build_marker"
  touch "$build_marker_file"

  run_build "$ANDROID_REPO_PATH" "$BUILD_COMMAND"

  mobile_output_dir="$(resolve_path "$MOBILE_APK_OUTPUT_DIR" "$ANDROID_REPO_PATH")"
  tv_output_dir="$(resolve_path "$TV_APK_OUTPUT_DIR" "$ANDROID_REPO_PATH")"

  mobile_apks=()
  while IFS= read -r apk_file; do
    [[ -n "$apk_file" ]] && mobile_apks+=("$apk_file")
  done < <(collect_apks "$mobile_output_dir" "$build_marker_file" "$ALLOW_STALE_APK_FALLBACK")

  tv_apks=()
  while IFS= read -r apk_file; do
    [[ -n "$apk_file" ]] && tv_apks+=("$apk_file")
  done < <(collect_apks "$tv_output_dir" "$build_marker_file" "$ALLOW_STALE_APK_FALLBACK")

  if ! is_truthy "$DRY_RUN"; then
    if is_truthy "$ENABLE_MOBILE_DISTRIBUTION" && [[ ${#mobile_apks[@]} -eq 0 ]] && is_truthy "$FAIL_IF_APK_NOT_FOUND"; then
      die "No APK files found for mobile in $mobile_output_dir"
    fi

    if is_truthy "$ENABLE_TV_DISTRIBUTION" && [[ ${#tv_apks[@]} -eq 0 ]] && is_truthy "$FAIL_IF_APK_NOT_FOUND"; then
      die "No APK files found for TV in $tv_output_dir"
    fi

    if [[ ${#mobile_apks[@]} -eq 0 && ${#tv_apks[@]} -eq 0 ]]; then
      die "No APK files found after build"
    fi
  else
    if [[ ${#mobile_apks[@]} -eq 0 ]]; then
      log "[DRY-RUN] No mobile APK found yet in $mobile_output_dir"
    fi

    if [[ ${#tv_apks[@]} -eq 0 ]]; then
      log "[DRY-RUN] No TV APK found yet in $tv_output_dir"
    fi
  fi

  if is_truthy "$has_real_merged_pr"; then
    default_release_notes="Automated distribution from merged PR #$latest_pr_number\nTitle: $latest_pr_title\nURL: $latest_pr_url\nMerged at: $latest_pr_merged_at"
  else
    default_release_notes="Automated distribution from manual force build\nBranch: $DEPLOY_GIT_BRANCH\nTriggered at: $latest_pr_merged_at"
  fi
  release_notes="$(read_release_notes "$default_release_notes")"

  if is_truthy "$ENABLE_MOBILE_DISTRIBUTION"; then
    if [[ ${#mobile_apks[@]} -gt 0 ]]; then
      distribute_apks "mobile" "$FIREBASE_APP_ID_MOBILE" "$FIREBASE_GROUPS_MOBILE" "$FIREBASE_TESTERS_MOBILE" "$release_notes" "${mobile_apks[@]}"
    else
      distribute_apks "mobile" "$FIREBASE_APP_ID_MOBILE" "$FIREBASE_GROUPS_MOBILE" "$FIREBASE_TESTERS_MOBILE" "$release_notes"
    fi
  else
    log "Mobile distribution is disabled"
  fi

  if is_truthy "$ENABLE_TV_DISTRIBUTION"; then
    if [[ ${#tv_apks[@]} -gt 0 ]]; then
      distribute_apks "tv" "$FIREBASE_APP_ID_TV" "$FIREBASE_GROUPS_TV" "$FIREBASE_TESTERS_TV" "$release_notes" "${tv_apks[@]}"
    else
      distribute_apks "tv" "$FIREBASE_APP_ID_TV" "$FIREBASE_GROUPS_TV" "$FIREBASE_TESTERS_TV" "$release_notes"
    fi
  else
    log "TV distribution is disabled"
  fi

  if is_truthy "$has_real_merged_pr"; then
    save_state "$STATE_FILE" "$DEPLOY_GIT_BRANCH" "$latest_pr_number" "$latest_pr_merged_at" "$latest_pr_url"
  else
    log "Skip state update because this run was not triggered by a merged PR"
  fi

  log "Pipeline completed successfully"
}

run "$@"
