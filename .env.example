# Copy this file to .env and replace placeholders with real values.
# cp .env.example .env

# Optional: branch to monitor (default main)
DEPLOY_GIT_BRANCH="main"

# Optional: override build command
BUILD_COMMAND="./gradlew :app-mobile:assembleVideohubDevRelease :app-tv:assembleVideohubDevRelease :app-tv:assembleSerieshubDevRelease :app-tv:assembleLiveHubDevRelease"

# Required for private repositories / higher API rate limit
GITHUB_TOKEN="ghp_xxx"

# Firebase auth (choose one):
# 1) FIREBASE_TOKEN from `firebase login:ci`
FIREBASE_TOKEN="firebase_ci_token"
# 2) or service account credentials
# GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/firebase-service-account.json"

# Required Firebase App IDs
FIREBASE_APP_ID_MOBILE="1:1234567890:android:mobileappid"
FIREBASE_APP_ID_TV="1:1234567890:android:tvappid"

# Optional testers/groups
FIREBASE_GROUPS_MOBILE="qa-mobile,product-owner"
FIREBASE_GROUPS_TV="qa-tv"
FIREBASE_TESTERS_MOBILE="alice@example.com,bob@example.com"
FIREBASE_TESTERS_TV="tvqa@example.com"

# Optional notes
# FIREBASE_RELEASE_NOTES="Automated release"
# FIREBASE_RELEASE_NOTES_FILE="./release-notes.txt"
