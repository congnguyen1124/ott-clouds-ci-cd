# Copy this file to .env and edit values.
# cp .env.example .env

# Path to Android project repository (relative to this folder or absolute path)
ANDROID_REPO_PATH=""

# Git branch listener settings
DEPLOY_GIT_BRANCH="main"
GIT_REMOTE_NAME="origin"
CHECK_INTERVAL_SECONDS="300"

# Build routing rules:
# - If merged branch name contains "app-tv" -> run BUILD_COMMAND_TV
# - If merged branch name contains "app-mobile" -> run BUILD_COMMAND_MOBILE
# - If both keywords appear -> run both commands
# - If neither keyword appears -> no build, only update state
MAX_MERGE_COMMITS_SCAN="20"
BUILD_COMMAND_TV=""
BUILD_COMMAND_MOBILE=""

# APK output folders (relative to ANDROID_REPO_PATH)
MOBILE_APK_OUTPUT_DIR=""
TV_APK_OUTPUT_DIR=""

# Runtime behavior
STATE_DIR=".state"
FAIL_IF_APK_NOT_FOUND="true"
ALLOW_STALE_APK_FALLBACK="true"

# Firebase App Distribution
ENABLE_DISTRIBUTION="true"
ENABLE_MOBILE_DISTRIBUTION="true"
ENABLE_VIDEOHUB_TV_DISTRIBUTION="true"
ENABLE_SERIESHUB_TV_DISTRIBUTION="true"
ENABLE_LIVEHUB_TV_DISTRIBUTION="true"

# Firebase project + app IDs (defaults below are for ottclouds-template-dev-22980)
FIREBASE_PROJECT_ID=""
FIREBASE_CLI_BIN=""
FIREBASE_APP_ID_VIDEOHUB_MOBILE=""
FIREBASE_APP_ID_VIDEOHUB_TV=""
FIREBASE_APP_ID_SERIESHUB_TV=""
FIREBASE_APP_ID_LIVEHUB_TV=""

# Dynamic mapping for APK target -> Firebase App
# Format: key=value;key=value (value can be Firebase app id OR app display name from `firebase apps:list`)
# Supported keys:
#   - <module>:<brand>      ex: app-tv:videohub
#   - <brand>-tv/mobile     ex: videohub-tv
#   - <brand>               ex: videohub
FIREBASE_TARGET_APP_MAP=""

# Default distribution group (auto-created if missing)
FIREBASE_DISTRIBUTION_GROUP_ALIAS=""
FIREBASE_DISTRIBUTION_GROUP_NAME=""

# Optional distribution recipients
FIREBASE_TESTERS_GLOBAL=""
FIREBASE_GROUPS_MOBILE=""
FIREBASE_GROUPS_VIDEOHUB_TV=""
FIREBASE_GROUPS_SERIESHUB_TV=""
FIREBASE_GROUPS_LIVEHUB_TV=""
FIREBASE_TESTERS_MOBILE=""
FIREBASE_TESTERS_VIDEOHUB_TV=""
FIREBASE_TESTERS_SERIESHUB_TV=""
FIREBASE_TESTERS_LIVEHUB_TV=""

# Optional dynamic recipients mapping (same key format as FIREBASE_TARGET_APP_MAP)
FIREBASE_TARGET_GROUPS_MAP=""
FIREBASE_TARGET_TESTERS_MAP=""

# Optional release notes and auth
FIREBASE_RELEASE_NOTES=""
FIREBASE_RELEASE_NOTES_FILE=""
# Recommended auth for CI/CD:
# GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/firebase-service-account.json"
# Legacy fallback (deprecated by firebase-tools):
# FIREBASE_TOKEN=""

# Optional: set this if java is not automatically detected
# JAVA_HOME="$HOME/Applications/Android Studio.app/Contents/jbr/Contents/Home"
